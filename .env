# =============================================================================
# Secret Migration Service - Environment Configuration (Production Ready)
# =============================================================================

# AWS Configuration
AWS_REGION=us-east-1

# S3 Buckets and Paths
SOURCE_BUCKET=uma-vault-to-aws-migration
DEST_BUCKET=uma-vault-to-aws-migration
JSON_KEY=input/vault-secrets.json
PROCESSED_KEY=02-cleansed/secrets_migration.json
PROCESSED_JSON_PATH=/tmp/processed-vault-secrets.json

# KMS Encryption
KMS_KEY_ARN=arn:aws:kms:us-east-1:212499160857:key/4d615aa0-162d-4e6c-9f84-d6d5ee769545

# Glue ETL Job
GLUE_JOB_NAME=Vault-to-SecretsManager-ETL

# DynamoDB
DDB_TABLE_NAME=vault-secrets-migration-state

# SNS Notification
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:212499160857:secrets-migration-notification

# Performance & Concurrency Tuning
MAX_CONCURRENT_WORKERS=160
MAX_SECRETS_PER_RUN=2000

# Rate Limiting & Backoff Strategy
INITIAL_DELAY_SEC=0.0
MAX_DELAY_SEC=0.75
DELAY_MULTIPLIER=1.7
DELAY_JITTER_MAX_MS=15

# Retry Policy for SecretsManager
MAX_RETRIES_PER_SECRET=7
RETRY_MIN_WAIT_SEC=0.6
RETRY_MAX_WAIT_SEC=3.0

# DynamoDB TTL (in days) - Items will auto-expire after this period
TTL_DAYS=180

# =============================================================================
# Optional overrides (uncomment if needed)
# =============================================================================
# LOG_LEVEL=INFO
# FASTMCP_PORT=8000